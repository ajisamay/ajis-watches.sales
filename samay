<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AJI'S WATCHES | Quetta Luxury</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Lato:wght@300;400;700&display=swap');

        :root {
            --gold: #d4af37;
            --leather: #4e3629;
            --dark: #0a0a0a;
            --card-bg: #161616;
            --cream: #fdfaf5;
        }

        body {
            background-color: var(--dark);
            color: var(--cream);
            font-family: 'Lato', sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

        header {
            background: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), 
                        url('https://images.unsplash.com/photo-1523170335258-f5ed11844a49?q=80&w=1200');
            background-size: cover;
            background-position: center;
            padding: 100px 20px;
            text-align: center;
            border-bottom: 3px solid var(--gold);
        }

        .store-name {
            font-family: 'Playfair Display', serif;
            font-size: 3.5rem;
            color: var(--gold);
            letter-spacing: 12px;
            margin: 0;
            text-transform: uppercase;
        }

        .tagline {
            font-size: 1rem;
            letter-spacing: 4px;
            margin-top: 15px;
            color: var(--cream);
            opacity: 0.8;
        }

        .shop-container {
            max-width: 1200px;
            margin: 60px auto;
            padding: 0 20px;
        }

        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 40px;
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid #222;
            padding: 25px;
            text-align: center;
            transition: 0.4s ease;
            border-bottom: 4px solid var(--leather);
        }

        .card:hover {
            transform: translateY(-10px);
            border-color: var(--gold);
        }

        .img-box {
            height: 250px;
            overflow: hidden;
            background: #000;
            margin-bottom: 20px;
        }

        .img-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        h3 {
            font-family: 'Playfair Display', serif;
            color: var(--gold);
            margin: 10px 0;
        }

        .description {
            font-size: 0.9rem;
            color: #bbb;
            line-height: 1.6;
            margin-bottom: 20px;
            font-style: italic;
        }

        .price {
            font-size: 1.4rem;
            margin-bottom: 20px;
        }

        .buy-btn {
            background: transparent;
            border: 1px solid var(--gold);
            color: var(--gold);
            padding: 12px 25px;
            cursor: pointer;
            text-transform: uppercase;
            width: 100%;
        }

        .buy-btn:hover {
            background: var(--gold);
            color: #000;
        }

        footer {
            text-align: center;
            padding: 40px;
            border-top: 1px solid #222;
            color: #666;
        }
    </style>
</head>
<body>

    <header>
        <h1 class="store-name">AJI'S WATCHES</h1>
        <p class="tagline">Classic Leather • Quetta Luxury • Est. 2026</p>
    </header>

    <main class="shop-container">
        <div class="product-grid">
            <!-- Box 1 -->
            <div class="card">
                <div class="img-box"><img src="https://img.drz.lazcdn.com/static/pk/p/4d222790c75f3a7c49ac53694f56ea16.jpg"></div>
                <h3>The Heritage Oak</h3>
                <p class="description">Genuine hand-selected brown leather with a sunburst dial. A classic for business professionals.</p>
                <p class="price">Rs. 18,500</p>
                <button class="buy-btn">Add to Bag</button>
            </div>

            <!-- Box 2 -->
            <div class="card">
                <div class="img-box"><img src="https://images.unsplash.com/photo-1547996160-81dfa63595aa?q=80&w=600"></div>
                <h3>The Noir Executive</h3>
                <p class="description">Matte black finish with premium suede straps. Modern, sleek, and comfortable for all-day wear.</p>
                <p class="price">Rs. 21,000</p>
                <button class="buy-btn">Add to Bag</button>
            </div>

            <!-- Box 3 -->
            <div class="card" style="border: 1px solid var(--gold);">
                <div class="img-box"><img src="https://img.drz.lazcdn.com/static/pk/p/f29b68d9f485f7a22a3683f2a893630b.jpg"></div>
                <h3>The Quetta Classic</h3>
                <p class="description">Our signature local piece. Crafted with rugged leather designed for the landscape of Balochistan.</p>
                <p class="price">Rs. 15,000</p>
                <button class="buy-btn">Add to Bag</button>
            </div>

            <!-- Box 4 -->
            <div class="card">
                <div class="img-box"><img src="https://images.unsplash.com/photo-1523170335258-f5ed11844a49?q=80&w=600"></div>
                <h3>The Midnight Gold</h3>
                <p class="description">Luxury 18K gold plating with deep espresso textured leather. A bold statement for any wrist.</p>
                <p class="price">Rs. 45,000</p>
                <button class="buy-btn">Add to Bag</button>
            </div>

            <!-- Box 5 -->
            <div class="card">
                <div class="img-box"><img src="https://images.unsplash.com/photo-1614164185128-e4ec99c436d7?q=80&w=600"></div>
                <h3>Silver Executive</h3>
                <p class="description">Polished silver casing paired with rare navy blue grain leather. The ultimate modern classic.</p>
                <p class="price">Rs. 38,000</p>
                <button class="buy-btn">Add to Bag</button>
            </div>

            <!-- Box 6 -->
            <div class="card">
                <div class="img-box"><img src="https://images.unsplash.com/photo-1522312346375-d1a52e2b99b3?q=80&w=600"></div>
                <h3>Royal Chrono</h3>
                <p class="description">Triple sub-dial functionality with hand-stitched mahogany leather. Built for collectors.</p>
                <p class="price">Rs. 52,000</p>
                <button class="buy-btn">Add to Bag</button>
            </div>
        </div>
    </main>

    <footer>
        <p>&copy; 2026 AJI'S WATCHES | Designed by AJI'S PRE DESIGN</p>
    </footer>

    <script>
        document.querySelectorAll('.buy-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                alert("Thank you! This luxury piece has been added to your bag.");
            });
        });
    </script>
</body>
</html>
